# ==============================================================================
# arti-ops v2.0 - Environment Configuration Example
#
# 이 파일을 복사하여 `.env` 파일을 생성한 후 실제 값을 채워주세요.
# ==============================================================================

# ------------------------------------------------------------------------------
# 📚 BookStack API (SSOT 기반 정책 동기화 계층)
# ------------------------------------------------------------------------------
# 사내 위키(BookStack) 연동을 위한 토큰 정보입니다. 관리자에게 발급받아 사용하세요.
BOOKSTACK_API_URL="https://wiki.your-company.com/api"
BOOKSTACK_TOKEN_ID="your_bookstack_token_id"
BOOKSTACK_TOKEN_SECRET="your_bookstack_token_secret"

# ------------------------------------------------------------------------------
# 💬 GWS Chat Webhook (HITL 승인 및 챗옵스 계층)
# ------------------------------------------------------------------------------
# 파괴적 변경사항 발생 시 즉시 PM 승인을 대기하기 위한 구글 워크스페이스 웹훅 주소입니다.
GWS_WEBHOOK_URL="https://chat.googleapis.com/v1/spaces/SPACE_ID/messages?key=KEY&token=TOKEN"

# ------------------------------------------------------------------------------
# ⚙️ Session Database (ADK Runner 상태 기록용)
# ------------------------------------------------------------------------------
# 기본값은 로컬 SQLite 파일(arti_ops_session.db)로 지정됩니다.
# (필요시 postgresql:// 등 다른 DB 호스트 URL로 변경 가능)
DATABASE_URL="sqlite:///arti_ops_session.db"
